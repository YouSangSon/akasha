# Akasha — environment variables
#
# Copy this file to `.env` and fill in the values. The compose.yaml and the
# Node process both read from this file (compose via env_file substitution,
# the app via process.env). For first-time setup, see ./install.sh.

# ─────────────────────────────────────────────────────────────────────────
# Required
# ─────────────────────────────────────────────────────────────────────────

# OpenAI API key — only required when EMBEDDING_PROVIDER=openai.
# The default provider is "transformers" (free local ONNX), so you can leave
# this commented out unless you flip the provider in the Embeddings section.
# Get a key at https://platform.openai.com/api-keys.
# OPENAI_API_KEY=sk-replace-me

# Bearer tokens that authenticate clients to the HTTP API.
# Format: comma-separated tokens, optionally with org binding ("token:org").
# Examples:
#   single token, any org:           dev-token
#   multi-token rotation:            old-token,new-token
#   org-bound token (multi-tenant):  alpha-token:dev-team,beta-token:finance-team
#
# Leave empty to disable auth — but the server will refuse to start when
# binding to a non-loopback host without tokens (fail-closed in production).
MEMORY_API_TOKENS=local-dev-token

# OAuth/OIDC protected-resource discovery + JWT validation for HTTP transports.
# Leave MCP_OAUTH_AUTHORIZATION_SERVERS unset to disable. When enabled, Akasha
# serves unauthenticated metadata at:
#   /.well-known/oauth-protected-resource
#   /.well-known/oauth-protected-resource/mcp
# /mcp and /v1/* accept either MEMORY_API_TOKENS static bearer tokens or JWT
# access tokens issued by one of the configured authorization servers for
# MCP_OAUTH_RESOURCE_URL. Use MCP_OAUTH_JWKS_URLS to pin JWKS endpoints; if it
# is omitted, Akasha discovers jwks_uri from OAuth/OIDC metadata.
# OAuth comma-separated lists reject blank entries when set.
# MCP_OAUTH_AUTHORIZATION_SERVERS=https://auth.example.com
# MCP_OAUTH_RESOURCE_URL=https://akasha.example.com/mcp
# MCP_OAUTH_SCOPES=akasha:read,akasha:write,akasha:admin
# MCP_OAUTH_JWKS_URLS=https://auth.example.com/.well-known/jwks.json
# MCP_OAUTH_JWT_ALGORITHMS=RS256,PS256,ES256,EdDSA
# MCP_OAUTH_JWT_CLOCK_TOLERANCE_SECONDS=60
# MCP_OAUTH_JWKS_TIMEOUT_MS=5000
# Optional OAuth text settings must contain non-whitespace text when set.
# MCP_OAUTH_JWT_TYPE=at+jwt
# MCP_OAUTH_ORGANIZATION_CLAIM=organization_id
# MCP_OAUTH_RESOURCE_NAME=Akasha Memory
# MCP_OAUTH_RESOURCE_DOCUMENTATION_URL=https://akasha.example.com/docs

# ─────────────────────────────────────────────────────────────────────────
# Postgres (defaults work with the bundled compose.yaml)
# ─────────────────────────────────────────────────────────────────────────

POSTGRES_USER=memory
# Local default for the bundled compose stack. In production, replace with a
# generated secret such as `openssl rand -hex 32`.
POSTGRES_PASSWORD=memory
POSTGRES_DB=memory_os
POSTGRES_PORT=5432

# Override DATABASE_URL to point at an external Postgres instead of the
# compose-managed one. Takes precedence over the POSTGRES_* vars above.
# DATABASE_URL=postgres://user:pw@host:5432/db

# ─────────────────────────────────────────────────────────────────────────
# Vector backend — qdrant (default) | pgvector (Postgres-only, no Qdrant)
# ─────────────────────────────────────────────────────────────────────────

VECTOR_BACKEND=qdrant

# ─────────────────────────────────────────────────────────────────────────
# Qdrant (only required when VECTOR_BACKEND=qdrant; defaults work with
# the bundled compose.yaml)
# ─────────────────────────────────────────────────────────────────────────

QDRANT_URL=http://localhost:6333
# Local default for the bundled compose stack. In production, replace with a
# generated secret such as `openssl rand -hex 32`.
QDRANT_API_KEY=local-qdrant-key
QDRANT_COLLECTION_NAME=memory_chunks_v1

# ─────────────────────────────────────────────────────────────────────────
# Server bind (HTTP API)
# ─────────────────────────────────────────────────────────────────────────

HOST=127.0.0.1
PORT=8787
NODE_ENV=production

# Structured log level. One of trace, debug, info, warn, error, fatal, silent
# (case-insensitive).
# Defaults to "info" in production and "debug" otherwise.
# LOG_LEVEL=info

# Stable user scope for user-memory tools when userScopeId is omitted.
# If unset, Akasha derives one from `git config user.email`, then OS username.
# If set, it must contain non-whitespace text.
# DEVELOPER_MEMORY_USER_ID=local-user

# ─────────────────────────────────────────────────────────────────────────
# Embeddings — defaults are good; change only if you need different behavior
# ─────────────────────────────────────────────────────────────────────────

# "transformers" (default) → free local ONNX inference via @huggingface/
#                            transformers. Default model:
#                            Xenova/all-MiniLM-L6-v2, 384-dim. First call
#                            downloads ~22MB to ~/.cache/huggingface/hub.
# "openai"                 → text-embedding-3-small via OpenAI API (paid).
#                            Requires OPENAI_API_KEY above.
# "local"                  → deterministic SHA-256 hash; semantically
#                            meaningless, plumbing tests / CI / air-gapped only.
EMBEDDING_PROVIDER=transformers
TRANSFORMERS_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
# Only meaningful when EMBEDDING_PROVIDER=openai:
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Only meaningful when EMBEDDING_PROVIDER=local or =transformers:
# EMBEDDING_DIMENSIONS=384
# EMBEDDING_MODEL=local-deterministic-v1   # (local provider only)

# ─────────────────────────────────────────────────────────────────────────
# Optional ops controls
# ─────────────────────────────────────────────────────────────────────────

# Per-token request rate limit. Unset = unlimited (not recommended in prod).
# RATE_LIMIT_PER_MINUTE=120

# Legacy single-tenant escape hatch for search_memory / build_context_pack.
# When organizationId is undefined on a request (no token-org binding, no
# x-organization-id header, no organizationId in the request body), the
# default-strict guard refuses the read with an error explaining how to
# satisfy it. Set to "true" only if you intentionally run org-blind reads —
# e.g. a single-tenant install that has no plans to add a second tenant.
# LEGACY_ANONYMOUS_SEARCH=true

# Background sweeper for the P17 compaction-apply Qdrant cleanup queue.
# Off by default; set true on one HTTP replica or on a dedicated
# `npm run start:worker` process that runs continuously.
# COMPACTION_SWEEP_ENABLED=false
# COMPACTION_SWEEP_INTERVAL_MS=30000

# Background sweeper that retries vector upserts left pending by the
# write-ahead ingest outbox (e.g. a crash between the Postgres write and the
# vector-store upsert). Off by default; set true on one HTTP replica or on a
# dedicated `npm run start:worker` process that runs continuously. Interval
# must be an integer ≥ 1000 (ms); defaults to 30000.
# INGEST_SWEEP_ENABLED=false
# INGEST_SWEEP_INTERVAL_MS=30000

# Backup output dir + optional remote SSH/scp target (used by `npm run backup:create`).
BACKUP_DIR=/var/lib/developer-memory-os/backups
BACKUP_TARGET_HOST=
# Optional remote directory. Defaults to BACKUP_DIR on BACKUP_TARGET_HOST.
# BACKUP_TARGET_DIR=/var/lib/developer-memory-os/backups
# Optional AES-256-GCM backup artifact encryption. File must contain a 32-byte AES key
# (hex, base64, or raw bytes). In KMS deployments, write/decrypt a data key to
# this file before running `npm run backup:create`.
# BACKUP_ENCRYPTION_KEY_FILE=/run/secrets/akasha-backup-data-key
# Set true only for a local debugging run; default removes plaintext artifacts
# after encrypted .enc artifacts are written and manifest checksums are updated.
# BACKUP_ENCRYPTION_KEEP_PLAINTEXT=false
