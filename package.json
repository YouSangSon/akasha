{
  "name": "developer-memory-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev:server": "tsx src/app/server.ts",
    "dev:mcp": "tsx src/mcp/server.ts",
